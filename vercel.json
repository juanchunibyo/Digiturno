{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": "vendor/**,app/**,config/**,bootstrap/**,routes/**,storage/**,database/**,public/**"
    }
  },
  "routes": [
    {
      "src": "/(build|assets|css|js|images|storage|favicon.ico|robots.txt)(.*)",
      "dest": "/$1$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}